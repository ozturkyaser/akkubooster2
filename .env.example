# ============================================
# BACKEND (Medusa 2.0)
# ============================================

# Database (Supabase Postgres)
DATABASE_URL=postgres://postgres:[password]@[host]:5432/postgres

# Redis (Upstash recommended)
REDIS_URL=redis://default:[password]@[host]:6379

# Medusa Auth
JWT_SECRET=replace_with_random_64_char_string
COOKIE_SECRET=replace_with_random_64_char_string

# CORS
STORE_CORS=http://localhost:3000,https://akkubooster.de
ADMIN_CORS=http://localhost:9000,https://admin.akkubooster.de
AUTH_CORS=http://localhost:3000,http://localhost:9000

# Stripe
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

# Email (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@akkubooster.de

# File Storage (S3 / Supabase Storage / R2)
S3_ENDPOINT=
S3_BUCKET=akkubooster-media
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FILE_URL=

# AI (Claude Vision)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Search (MeiliSearch)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=

# ============================================
# STOREFRONT (Next.js)
# ============================================

NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxx
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_REGION=de
NEXT_PUBLIC_STRIPE_KEY=pk_test_xxx

# Optional — Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ============================================
# SHOPIFY IMPORT (einmalig, nur für Migration)
# ============================================

SHOPIFY_SHOP_DOMAIN=akkubooster.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx
