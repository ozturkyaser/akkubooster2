# ============================================
# AkkuBooster — Production ENV (Docker Compose)
# ============================================
# Auf dem Server:
#   cp .env.production.example .env.production
#   nano .env.production       # Werte eintragen
#   ./deploy.sh

# ── PUBLIC URLS (mit https) ──
PUBLIC_STOREFRONT_URL=https://dev.akkubooster.de
PUBLIC_BACKEND_URL=https://admin.dev.akkubooster.de

# ── DATENBANK ──
# Starkes Passwort generieren:  openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── MEDUSA SECRETS ──
# Beide neu generieren:  openssl rand -base64 64
JWT_SECRET=CHANGE_ME_random_64_chars
COOKIE_SECRET=CHANGE_ME_random_64_chars

# ── CORS ──
STORE_CORS=https://dev.akkubooster.de
ADMIN_CORS=https://admin.dev.akkubooster.de
AUTH_CORS=https://dev.akkubooster.de,https://admin.dev.akkubooster.de

# ── MEDUSA STOREFRONT KEY ──
# Wird nach 1. Backend-Start im Admin generiert (Settings → Publishable API Keys)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_CHANGE_ME

# ── REGION ──
NEXT_PUBLIC_DEFAULT_REGION=de

# ── SANITY (Content) ──
NEXT_PUBLIC_SANITY_PROJECT_ID=ep5dzepn
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_STUDIO_URL=https://akkubooster.sanity.studio
SANITY_API_READ_TOKEN=CHANGE_ME_sanity_read_token

# ── STRIPE ──
STRIPE_API_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
NEXT_PUBLIC_STRIPE_KEY=pk_live_CHANGE_ME

# ── PAYPAL ──
PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME
PAYPAL_SANDBOX=false
NEXT_PUBLIC_PAYPAL_CLIENT_ID=CHANGE_ME

# ── ANTHROPIC (KI-Check / Diagnose) ──
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── EMAIL (Resend) ──
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=noreply@akkubooster.de

# ── REVALIDATE-SECRET (Sanity → Next.js Webhook) ──
# openssl rand -hex 32
REVALIDATE_SECRET=CHANGE_ME_random_hex

# ── OPTIONAL: S3 / Object Storage fuer Medien ──
# S3_ENDPOINT=
# S3_BUCKET=akkubooster-media
# S3_REGION=eu-central-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FILE_URL=

# ── OPTIONAL: SHOPIFY IMPORT ──
# SHOPIFY_SHOP_DOMAIN=akkubooster.myshopify.com
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_CHANGE_ME
